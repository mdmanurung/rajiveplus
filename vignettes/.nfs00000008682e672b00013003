#!/usr/bin/env Rscript
# Generate all cache files for microbiome_application.Rmd
# Run once from the package root:
#   conda run -n R4_51 Rscript vignettes/generate_microbiome_cache.R

suppressPackageStartupMessages({
  library(data.table)
  devtools::load_all(".", quiet = TRUE)
})

data_dir <- "vignettes/data"
dir.create(data_dir, showWarnings = FALSE, recursive = TRUE)

# ---- Step 1: Download raw data from EBI FTP ----
cat("[1/6] Downloading raw data from EBI FTP...\n")
dt       <- data.table::fread(
  "ftp://ftp.ebi.ac.uk/pub/databases/mofa/microbiome/data.txt.gz"
)
metadata <- data.table::fread(
  "ftp://ftp.ebi.ac.uk/pub/databases/mofa/microbiome/metadata.txt.gz"
)
saveRDS(list(dt = dt, metadata = metadata),
        file.path(data_dir, "microbiome_raw.rds"))
cat("    -> saved microbiome_raw.rds\n")

# ---- Step 2: Preprocess to matrix blocks ----
cat("[2/6] Preprocessing to matrix blocks...\n")
view_names <- unique(dt$view)
cat("    Views found:", paste(view_names, collapse = ", "), "\n")

mat_list <- lapply(setNames(view_names, view_names), function(v) {
  sub  <- dt[view == v]
  wide <- data.table::dcast(sub, sample ~ feature,
                            value.var = "value", fill = 0)
  mat  <- as.matrix(wide[, -1, with = FALSE])
  rownames(mat) <- wide$sample
  mat
})

common_samples <- Reduce(intersect, c(
  lapply(mat_list, rownames),
  list(metadata$sample)
))
cat("    Samples in common:", length(common_samples), "\n")

scale_block <- function(m) {
  s <- scale(m[common_samples, , drop = FALSE],
             center = TRUE, scale = TRUE)
  s[is.nan(s)] <- 0
  s
}
blocks <- lapply(mat_list, scale_block)
meta_s <- as.data.frame(metadata)[
  match(common_samples, metadata$sample), ]
rownames(meta_s) <- common_samples

saveRDS(list(blocks = blocks, meta = meta_s),
        file.path(data_dir, "microbiome_preprocessed.rds"))
cat("    -> saved microbiome_preprocessed.rds\n")
cat("    Block dims:", paste(sapply(blocks, function(b) paste(dim(b), collapse="x")), collapse=", "), "\n")

# ---- Step 3: SVD for scree plots ----
cat("[3/6] Computing per-block SVD for scree plots...\n")
svd_list <- lapply(blocks, function(m) svd(m, nu = 0, nv = 0)$d)
saveRDS(svd_list,
        file.path(data_dir, "microbiome_svd_list.rds"))
cat("    -> saved microbiome_svd_list.rds\n")

# ---- Step 4: Fit RaJIVE model ----
# Choose initial signal ranks based on scree elbows
n_blocks <- length(blocks)
# Use conservative ranks: 5 for Bacteria, 4 for Fungi/middle blocks, 3 for Viruses/last
init_ranks <- switch(as.character(n_blocks),
  "3" = c(5L, 4L, 3L),
  "2" = c(5L, 4L),
  rep(4L, n_blocks)
)
# Match to actual view order
if (!is.null(names(blocks))) {
  nm <- tolower(names(blocks))
  init_ranks_named <- sapply(nm, function(v) {
    if (grepl("bact", v)) 5L
    else if (grepl("fung", v)) 4L
    else if (grepl("vir",  v)) 3L
    else 4L
  })
  init_ranks <- unname(init_ranks_named)
}
cat("    Initial signal ranks:", paste(names(blocks), init_ranks, sep="=", collapse=", "), "\n")

cat("[4/6] Fitting Rajive() model...\n")
set.seed(42)
mb_fit <- Rajive(
  blocks               = blocks,
  initial_signal_ranks = init_ranks,
  full                 = TRUE,
  n_wedin_samples      = 500L,
  n_rand_dir_samples   = 500L,
  joint_rank           = NA,
  num_cores            = 4L
)
cat("    Estimated joint rank:", get_joint_rank(mb_fit), "\n")
saveRDS(mb_fit,
        file.path(data_dir, "microbiome_rajive_results.rds"))
cat("    -> saved microbiome_rajive_results.rds\n")

# ---- Step 5: Jackstraw significance testing ----
cat("[5/6] Running jackstraw_rajive()...\n")
set.seed(42)
mb_js <- jackstraw_rajive(
  ajive_output = mb_fit,
  blocks       = blocks,
  alpha        = 0.05,
  n_null       = 50L,
  correction   = "BH"
)
saveRDS(mb_js,
        file.path(data_dir, "microbiome_jackstraw_results.rds"))
cat("    -> saved microbiome_jackstraw_results.rds\n")

# ---- Step 6: Bootstrap rank stability ----
cat("[6/6] Bootstrap rank stability (B=30)...\n")
set.seed(42)
stab <- assess_stability(
  ajive_output         = mb_fit,
  blocks               = blocks,
  initial_signal_ranks = init_ranks,
  target               = "joint_rank",
  B                    = 30L,
  sample_frac          = 0.8,
  num_cores            = 4L
)
saveRDS(stab,
        file.path(data_dir, "microbiome_stability.rds"))
cat("    -> saved microbiome_stability.rds\n")

cat("\nAll 6 cache files generated successfully.\n")
cat("RDS files in", data_dir, ":\n")
cat(paste("  ", list.files(data_dir, "microbiome.*\\.rds")), sep = "\n")
